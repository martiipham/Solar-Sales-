# Solar Swarm — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control

# ── OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── GoHighLevel CRM
GHL_API_KEY=your-ghl-api-key-here
GHL_LOCATION_ID=your-ghl-location-id-here
GHL_PIPELINE_ID=
# HMAC-SHA256 secret — set in GHL → Settings → Webhooks → Signing Secret
GHL_WEBHOOK_SECRET=your-ghl-webhook-signing-secret-here

# ── Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# xoxb-... bot token — required for interactive approve/reject buttons
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#swarm-alerts
# Signing secret — required to verify Slack interactive action payloads
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# ── Human Gate API (protects /approve, /reject, /dashboard, etc.)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GATE_API_KEY=your-gate-api-key-here
# JWT token expiry in seconds (default 86400 = 24h). Tokens issued by POST /auth/token.
GATE_TOKEN_EXPIRY=86400

# ── Rate limiter storage (optional — uses in-memory if not set)
# Set to a Redis URL for persistence across restarts and multi-process deployments.
# Example: redis://localhost:6379/0
REDIS_URL=

# ── HubSpot (optional CRM)
HUBSPOT_API_KEY=

# ── Salesforce (optional CRM)
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ── Voice AI — Retell
RETELL_API_KEY=
RETELL_DEFAULT_VOICE_ID=11labs-Adrian
VOICE_WEBHOOK_BASE_URL=https://your-server.com
TRANSFER_PHONE=+61400000000

# ── Voice AI — ElevenLabs (optional alternative)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE=

# ── Email processing (optional IMAP polling)
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_FOLDER=INBOX

# ── Budget Settings (AUD)
WEEKLY_BUDGET_AUD=500

# ── Flask Ports
PORT_HUMAN_GATE=5000
PORT_GHL_WEBHOOKS=5001
PORT_VOICE_WEBHOOK=5002
PORT_DASHBOARD_API=5003

# ── Database
DATABASE_PATH=swarm.db

# ── Logging
LOG_LEVEL=INFO

# ── Default client ID (used when phone number not mapped to a company profile)
DEFAULT_CLIENT_ID=default
